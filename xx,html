<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mục lục: Hôm nay mèo con cũng cứu vớt vai ác - Little Mint's Galaxy</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;1,400;1,600&display=swap" rel="stylesheet">

    <style>
        :root {
            --bg-image: url('background.jpg');
            --container-bg: rgba(255, 255, 255, 0.4);
            --text-color: #4a3728;
            --header-color: #5d4737;
            --border-color: #8d7561;
            --box-shadow: inset 0 0 15px rgba(141, 117, 97, 0.1), 0 4px 20px rgba(0, 0, 0, 0.08);
            --link-hover-bg: rgba(255, 255, 255, 0.6);
        }

        [data-theme="dark"] {
            --bg-image: linear-gradient(rgba(20, 16, 14, 0.85), rgba(20, 16, 14, 0.85)), url('background.jpg');
            --container-bg: rgba(35, 30, 27, 0.9);
            --text-color: #e2d7cc;
            --header-color: #f1e6da;
            --border-color: #5d4737;
            --box-shadow: inset 0 0 15px rgba(0, 0, 0, 0.5), 0 4px 20px rgba(0, 0, 0, 0.4);
            --link-hover-bg: rgba(255, 255, 255, 0.08);
        }

        body { background-image: var(--bg-image); background-attachment: fixed; background-size: cover; background-position: center; font-family: 'Lora', Georgia, Serif; color: var(--text-color); margin: 0; padding: 0; transition: background 0.3s ease, color 0.3s ease; }

        .theme-toggle-btn { position: fixed; top: 25px; right: 25px; width: 45px; height: 45px; background-color: #5d4737; color: #ffffff; border: 2px solid #8d7561; border-radius: 50%; cursor: pointer; font-size: 20px; display: flex; align-items: center; justify-content: center; z-index: 1000; box-shadow: 0 4px 10px rgba(0,0,0,0.2); transition: transform 0.2s, background-color 0.2s; }
        .theme-toggle-btn:hover { transform: scale(1.1); background-color: #7a5f4a; }

        .header-container { text-align: center; padding-top: 50px; padding-bottom: 30px; }
        .site-title { font-size: 45px; margin: 10px 0; font-weight: normal; color: var(--header-color); }
        .site-slogan { font-style: italic; font-size: 18px; margin-bottom: 30px; color: var(--text-color); }

        .nav-bar { display: flex; justify-content: center; gap: 20px; margin-bottom: 50px; position: relative; z-index: 999; }
        .dropdown { position: relative; display: inline-block; }
        .nav-item { background-color: #5d4737; color: #ffffff; text-decoration: none; padding: 8px 20px; font-size: 14px; font-weight: bold; text-transform: uppercase; border-radius: 2px; display: block; font-family: 'Lora', Georgia, Serif; border: none; }
        a.nav-item:hover { background-color: #7a5f4a; }
        .dropdown-content { display: none; position: absolute; background-color: #5d4737; min-width: 220px; box-shadow: 0px 8px 16px rgba(0,0,0,0.2); border-radius: 2px; top: 100%; left: 50%; transform: translateX(-50%); padding: 5px 0; }
        .dropdown-content a { color: #ffffff; padding: 10px 15px; text-decoration: none; display: block; font-size: 13px; text-align: left; border-bottom: 1px dashed rgba(255, 255, 255, 0.1); transition: 0.2s; }
        .dropdown-content a:hover { background-color: #7a5f4a; padding-left: 20px; }
        .dropdown:hover .dropdown-content { display: block; }

        .novel-info-container, .novel-chapters-container, .chapter-discussion-box { max-width: 850px; width: 90%; margin: 0 auto 30px; padding: 40px; background-color: var(--container-bg); border: 1px solid var(--border-color); border-radius: 2px; box-shadow: var(--box-shadow); box-sizing: border-box; }
        
        .novel-layout-flex { display: flex; gap: 30px; }
        .novel-cover-cell { width: 220px; flex-shrink: 0; }
        .novel-meta-cell { flex-grow: 1; text-align: left; }
        .novel-cover-frame { width: 220px; height: 330px; border: 8px solid #fff; box-shadow: 0 5px 15px rgba(0,0,0,0.2); overflow: hidden; box-sizing: border-box; }
        .novel-cover-frame img { width: 100%; height: 100%; object-fit: cover; }
        .novel-title { font-size: 26px; color: var(--header-color); margin: 0 0 15px 0; }
        .novel-details { font-size: 14px; line-height: 1.8; margin-bottom: 20px; border-bottom: 1px dashed var(--border-color); padding-bottom: 15px; }
        .novel-summary-title { font-size: 16px; font-weight: bold; color: var(--header-color); margin-bottom: 15px; text-transform: uppercase; }
        .novel-summary-text { font-size: 15px; line-height: 1.8; text-align: justify; }

        /* KHUNG CẢNH BÁO */
        .notice-frame { border: 2px dashed #8d7561; border-radius: 15px; padding: 15px; margin-top: 20px; text-align: center; background-color: rgba(93, 71, 55, 0.05); }
        .notice-text { font-style: italic; font-weight: bold; color: #4a3728; font-size: 14px; }

        #chapter-label { display: flex; align-items: center; justify-content: center; color: var(--header-color); font-size: 18px; letter-spacing: 6px; font-weight: bold; margin: 0 0 40px 0; }
        #chapter-label::before, #chapter-label::after { content: ""; flex: 1; border-bottom: 1px solid var(--border-color); margin: 0 20px; }
        .chapter-grid-new { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px 20px; }
        .chapter-link { display: block; color: var(--text-color); padding: 8px 12px; border-bottom: 1px dashed rgba(93, 71, 55, 0.2); text-decoration: none; }
        .chapter-link:hover { color: var(--header-color); font-weight: bold; padding-left: 18px; background-color: var(--link-hover-bg); }

        /* LIKE & COMMENT */
        .like-chapter-container { max-width: 850px; width: 90%; margin: 0 auto 30px; }
        .like-chapter-wrapper { cursor: pointer; color: var(--text-color); display: inline-block; }
        .like-chapter-wrapper:hover { color: #a86232; }
        .like-title-line { font-size: 19px; font-weight: 600; color: var(--header-color); }
        .discussion-title { font-size: 18px; color: var(--header-color); border-bottom: 1px solid var(--border-color); padding-bottom: 10px; margin-bottom: 20px; }
    </style>
</head>
